{
  "name": "apesdb",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "src/frontend/apesdb/src",
  "implicitDependencies": ["ui", "common"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite build --config src/frontend/apesdb/vite.config.ts"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite --config src/frontend/apesdb/vite.config.ts --host 0.0.0.0"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "oxlint src/frontend/apesdb --deny-warnings"
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "oxfmt --write src/frontend/apesdb"
      }
    },
    "format:check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "oxfmt --check src/frontend/apesdb"
      }
    }
  }
}
